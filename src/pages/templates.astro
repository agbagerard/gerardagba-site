---
import BaseLayout from "../layouts/BaseLayout.astro";
import EmailCapture from "../components/EmailCapture.astro";

// Each item: episode number, slug, title, blurb, live status
// For live items, downloads live at:
//   /downloads/<slug>.zip
//   /downloads/<slug>-setup-guide.pdf
const categories = [
  {
    name: "Revenue & Sales Reconciliation",
    blurb: "Every dollar earned tracked, verified, and moved correctly through the books.",
    items: [
      { n: "01", slug: "multi-channel-sales-sync", title: "Multi-Channel Sales Sync", blurb: "Reconcile Shopify, Amazon, Faire, PayPal, Klarna into one ledger.", live: true },
      { n: "02", slug: "amazon-fba-fee-auditor", title: "Amazon FBA Fee Auditor", blurb: "Catches the $2-5K/month FBA fee errors most brands never check.", live: true },
      { n: "03", slug: "payment-processor-audit", title: "Payment Processor Audit", blurb: "Stripe + PayPal payouts vs bank, dollar for dollar.", live: false },
      { n: "04", slug: "settle-gl-reconciliation", title: "Settle GL Reconciliation", blurb: "Settle bill pay + multi-channel revenue + bank → balanced QBO journal entries.", live: true },
      { n: "04", slug: "real-time-cogs-calculator", title: "Real-Time COGS Calculator", live: false },
      { n: "05", slug: "tax-jurisdiction-tracker", title: "Tax Jurisdiction Tracker", live: false },
      { n: "06", slug: "refund-recovery-guard", title: "Refund Recovery Guard", live: false },
      { n: "07", slug: "subscription-mrr-tracker", title: "Subscription MRR Tracker", live: false },
      { n: "08", slug: "gift-card-liability-logger", title: "Gift Card Liability Logger", live: false },
      { n: "09", slug: "store-credit-manager", title: "Store Credit Manager", live: false },
      { n: "10", slug: "currency-auto-adjustment", title: "Currency Auto-Adjustment", live: false },
    ],
  },
  {
    name: "Inventory & Supply Chain Finance",
    blurb: "Stop dead money sitting in the warehouse.",
    items: [
      { n: "11", slug: "low-stock-capital-forecaster", title: "Low Stock Capital Forecaster", live: false },
      { n: "12", slug: "inventory-aging-alert", title: "Inventory Aging Alert", live: false },
      { n: "13", slug: "po-to-invoice-matcher", title: "PO to Invoice Matcher", live: false },
      { n: "14", slug: "lead-time-buffer-adjuster", title: "Lead-Time Buffer Adjuster", live: false },
      { n: "15", slug: "drop-ship-margin-monitor", title: "Drop-Ship Margin Monitor", live: false },
    ],
  },
  {
    name: "Expense & Overhead Management",
    blurb: "Eliminate administrative leakage and watch the burn rate.",
    items: [
      { n: "21", slug: "ad-spend-roi-guard", title: "Ad Spend ROI Guard", live: false },
      { n: "22", slug: "saas-subscription-auditor", title: "SaaS Subscription Auditor", live: false },
      { n: "25", slug: "receipt-to-ledger-ocr", title: "Receipt-to-Ledger OCR", live: false },
      { n: "30", slug: "cash-flow-runway-forecaster", title: "Cash Flow Runway Forecaster", live: false },
    ],
  },
  {
    name: "Customer & Growth Accounting",
    blurb: "Turn customer behavior into financial signal.",
    items: [
      { n: "31", slug: "ltv-segmenter", title: "LTV (Lifetime Value) Segmenter", live: false },
      { n: "32", slug: "chargeback-response-builder", title: "Chargeback Response Builder", live: false },
      { n: "37", slug: "automated-dunning-logic", title: "Automated Dunning Logic", live: false },
    ],
  },
  {
    name: "Compliance, Tax & Audit",
    blurb: "Audit-proof the business.",
    items: [
      { n: "41", slug: "audit-ready-document-vault", title: "Audit-Ready Document Vault", live: false },
      { n: "42", slug: "sales-tax-nexus-alert", title: "Sales Tax Nexus Alert", live: false },
      { n: "43", slug: "1099-contractor-tracker", title: "1099 Contractor Tracker", live: false },
      { n: "50", slug: "balance-sheet-health-check", title: "Balance Sheet Health Check", live: false },
    ],
  },
];
---
<BaseLayout
  title="Free n8n Templates · Gerard Agba"
  description="Every free n8n workflow I've shipped. Multi-channel reconciliation, FBA fee audits, chargeback recovery, and more. Direct downloads, no email gate."
>
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-12">
    <p class="text-xs uppercase tracking-widest text-[color:var(--color-accent)] mb-4">Free templates</p>
    <h1 class="text-4xl md:text-5xl font-extrabold leading-tight tracking-tight max-w-3xl">
      Every n8n workflow I&rsquo;ve shipped &mdash; free, direct download, no email required.
    </h1>
    <p class="text-lg text-[color:var(--color-muted)] mt-6 max-w-2xl">
      Each template comes with the n8n JSON, a 1-page setup guide, and a video walkthrough.
      Newsletter at the bottom of the page if you want to know when a new one drops.
    </p>
  </section>

  {categories.map((cat) => (
    <section class="max-w-5xl mx-auto px-6 mt-16">
      <h2 class="text-2xl md:text-3xl font-bold mb-2">{cat.name}</h2>
      <p class="text-[color:var(--color-muted)] mb-6">{cat.blurb}</p>
      <div class="grid gap-3">
        {cat.items.map((item) => (
          item.live ? (
            <div class="p-5 rounded-lg border border-white/10 bg-white/[0.02] hover:border-[color:var(--color-accent)]/40 transition">
              <div class="flex items-start justify-between gap-4 flex-wrap">
                <div class="min-w-0 flex-1">
                  <div class="text-xs text-[color:var(--color-accent)] mb-1">EP {item.n}</div>
                  <div class="font-semibold mb-1">{item.title}</div>
                  {item.blurb && <p class="text-sm text-[color:var(--color-muted)]">{item.blurb}</p>}
                </div>
                <div class="flex gap-2 shrink-0 flex-wrap">
                  <a
                    href={`/downloads/${item.slug}.zip`}
                    class="px-3 py-1.5 rounded-md bg-[color:var(--color-accent)] text-black text-sm font-semibold hover:opacity-90 transition whitespace-nowrap"
                    download
                  >
                    Download workflow
                  </a>
                  <a
                    href={`/downloads/${item.slug}-setup-guide.pdf`}
                    class="px-3 py-1.5 rounded-md border border-white/15 hover:border-white/40 text-sm font-medium transition whitespace-nowrap"
                  >
                    Setup guide (PDF)
                  </a>
                  <a
                    href={`/episodes/${item.slug}`}
                    class="px-3 py-1.5 rounded-md text-[color:var(--color-muted)] hover:text-white text-sm font-medium transition whitespace-nowrap"
                  >
                    Watch episode →
                  </a>
                </div>
              </div>
            </div>
          ) : (
            <div class="p-5 rounded-lg border border-white/5 opacity-50">
              <div class="flex items-center justify-between gap-4">
                <div class="min-w-0 flex-1">
                  <div class="text-xs text-[color:var(--color-muted)] mb-1">EP {item.n} · COMING SOON</div>
                  <div class="font-medium">{item.title}</div>
                  {item.blurb && <p class="text-sm text-[color:var(--color-muted)] mt-1">{item.blurb}</p>}
                </div>
                <span class="text-xs text-[color:var(--color-muted)] shrink-0">Soon</span>
              </div>
            </div>
          )
        ))}
      </div>
    </section>
  ))}

  <section class="max-w-5xl mx-auto px-6 mt-20">
    <EmailCapture
      heading="Know when the next one drops"
      subheading="One email per new episode. Nothing else."
      tag="newsletter"
    />
  </section>
</BaseLayout>
