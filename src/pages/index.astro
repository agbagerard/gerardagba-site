---
import BaseLayout from "../layouts/BaseLayout.astro";
import EmailCapture from "../components/EmailCapture.astro";

const episodes = [
  {
    n: "01",
    slug: "multi-channel-sales-sync",
    title: "Multi-Channel Sales Sync",
    blurb: "Reconcile Shopify, Amazon, Faire, PayPal & Klarna into one clean ledger in 12 minutes.",
    live: true,
  },
  { n: "02", slug: "amazon-fba-fee-auditor", title: "Amazon FBA Fee Auditor", blurb: "Catch the fees Amazon mischarges — most brands leak $2-5K/mo.", live: true },
  { n: "03", slug: "payment-processor-audit", title: "Payment Processor Audit", blurb: "Match Stripe/PayPal payouts to your bank, dollar-for-dollar.", live: false },
  { n: "04", slug: "settle-gl-reconciliation", title: "Settle GL Reconciliation", blurb: "Settle bill pay + multi-channel revenue + bank → balanced QBO journal entries.", live: true },
];
---
<BaseLayout>
  <!-- HERO -->
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-16">
    <p class="text-xs uppercase tracking-widest text-[color:var(--color-accent)] mb-4">
      n8n workflows for DTC finance
    </p>
    <h1 class="text-4xl md:text-6xl font-extrabold leading-[1.05] tracking-tight max-w-4xl">
      Free n8n workflows that recover the money your DTC books are leaking.
    </h1>
    <p class="text-lg md:text-xl text-[color:var(--color-muted)] mt-6 max-w-2xl">
      Every episode I take one expensive, manual finance task at a DTC brand &mdash;
      multi-channel reconciliation, FBA fee audits, chargeback recovery &mdash; and
      ship the n8n workflow that fixes it. Free. JSON included.
    </p>
    <div class="flex flex-wrap gap-3 mt-8">
      <a href="/templates" class="px-6 py-3 rounded-lg bg-white text-black font-semibold hover:bg-white/90 transition">
        See all templates →
      </a>
      <a href="/work-with-me" class="px-6 py-3 rounded-lg border border-white/15 hover:border-white/40 transition">
        Work with me
      </a>
    </div>
  </section>

  <!-- EPISODES -->
  <section id="episodes" class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-2xl md:text-3xl font-bold mb-8">Episodes</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {episodes.map((ep) => (
        <a
          href={ep.live ? `/episodes/${ep.slug}` : "#"}
          class={`block p-6 rounded-xl border border-white/10 transition ${ep.live ? "hover:border-[color:var(--color-accent)] hover:bg-white/[0.02]" : "opacity-50 cursor-not-allowed"}`}
        >
          <div class="text-xs text-[color:var(--color-muted)] mb-2">EPISODE {ep.n}{!ep.live && " · COMING SOON"}</div>
          <h3 class="text-xl font-semibold mb-2">{ep.title}</h3>
          <p class="text-sm text-[color:var(--color-muted)]">{ep.blurb}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- EMAIL CAPTURE (newsletter) -->
  <section id="templates" class="max-w-6xl mx-auto px-6 py-8">
    <EmailCapture
      heading="Get every new workflow free"
      subheading="One email when a new episode drops. Workflow JSON + setup guide included."
      tag="newsletter"
    />
  </section>
</BaseLayout>
