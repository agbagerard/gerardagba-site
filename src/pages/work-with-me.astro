---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Work with me · Gerard Agba" description="I install n8n finance automation for DTC brands doing $2-15M ARR. Fixed-scope, fixed-price, done in 2 weeks.">
  <section class="max-w-3xl mx-auto px-6 pt-20 pb-16">
    <p class="text-xs uppercase tracking-widest text-[color:var(--color-accent)] mb-4">Work with me</p>
    <h1 class="text-4xl md:text-5xl font-extrabold leading-tight tracking-tight">
      I install n8n finance automation for DTC brands &mdash; in 2 weeks, fixed-price.
    </h1>
    <p class="text-lg text-[color:var(--color-muted)] mt-6">
      You bring the channels (Shopify, Amazon, Faire, Stripe, Klarna, PayPal, Mercury).
      I build, deploy, and document the workflow. You own it forever.
    </p>

    <div class="mt-12 space-y-6">
      <div class="p-6 rounded-xl border border-white/10">
        <h3 class="font-semibold text-lg mb-2">Reconciliation Sprint &mdash; $4,500</h3>
        <p class="text-sm text-[color:var(--color-muted)]">Multi-channel sales sync + journal entries + month-end summary. 2 weeks.</p>
      </div>
      <div class="p-6 rounded-xl border border-white/10">
        <h3 class="font-semibold text-lg mb-2">Full Finance OS &mdash; $12,000</h3>
        <p class="text-sm text-[color:var(--color-muted)]">Reconciliation + FBA fee auditor + chargeback recovery + cash-flow forecaster. 4 weeks.</p>
      </div>
      <div class="p-6 rounded-xl border border-white/10">
        <h3 class="font-semibold text-lg mb-2">Custom Build &mdash; from $15,000</h3>
        <p class="text-sm text-[color:var(--color-muted)]">Anything from the 50-workflow library, scoped to your stack.</p>
      </div>
    </div>

    <div class="mt-12">
      <!--
        TODO: rename the Calendly event type from "Brand Voice Concierge — Discovery Call"
        to something like "n8n Reconciliation Sprint — 20-min Discovery" and update the
        link below to the specific event URL once renamed.
        For now this is the generic scheduling page.
      -->
      <a
        href="https://calendly.com/agbagerard/n8n-reconciliation-sprint-discovery"
        target="_blank"
        rel="noopener"
        class="inline-block px-6 py-3 rounded-lg bg-[color:var(--color-accent)] text-black font-semibold hover:opacity-90 transition"
      >
        Book a discovery call →
      </a>
    </div>
  </section>
</BaseLayout>
