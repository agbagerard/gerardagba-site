---
const year = new Date().getFullYear();

const YOUTUBE = "https://www.youtube.com/channel/UCYXFvi5l74GkWdxfaMuXtCA";
const LINKEDIN = "https://www.linkedin.com/in/denakpo-agba/";
// Public email — set up free email forwarding at your domain registrar
// (Porkbun: hello@agbagerard.com → agbagerard@gmail.com)
const EMAIL = "hello@agbagerard.com";
---
<footer class="border-t border-white/5 mt-24">
  <div class="max-w-6xl mx-auto px-6 py-10 grid md:grid-cols-3 gap-6 text-sm text-[color:var(--color-muted)]">
    <div>
      <div class="font-semibold text-white mb-2">GERARD AGBA</div>
      <p class="max-w-xs">n8n workflows for the firms and finance teams that close the books on DTC. Free episodes, paid installs.</p>
    </div>

    <div>
      <div class="font-semibold text-white mb-2">Site</div>
      <ul class="space-y-1">
        <li><a href="/" class="hover:text-white transition">Home</a></li>
        <li><a href="/templates" class="hover:text-white transition">Free Templates</a></li>
        <li><a href="/about" class="hover:text-white transition">About</a></li>
        <li><a href="/work-with-me" class="hover:text-white transition">Work with me</a></li>
      </ul>
    </div>

    <div>
      <div class="font-semibold text-white mb-2">Elsewhere</div>
      <ul class="space-y-1">
        <li><a href={YOUTUBE} target="_blank" rel="noopener" class="hover:text-white transition">YouTube</a></li>
        <li><a href={LINKEDIN} target="_blank" rel="noopener" class="hover:text-white transition">LinkedIn</a></li>
        <li><a href={`mailto:${EMAIL}`} class="hover:text-white transition">{EMAIL}</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/5">
    <div class="max-w-6xl mx-auto px-6 py-5 flex flex-col md:flex-row gap-3 justify-between text-xs text-[color:var(--color-muted)]">
      <div>GERARD AGBA · © {year}</div>
      <div class="flex gap-5">
        <a href="/privacy" class="hover:text-white transition">Privacy</a>
        <a href="/terms" class="hover:text-white transition">Terms</a>
      </div>
    </div>
  </div>
</footer>
